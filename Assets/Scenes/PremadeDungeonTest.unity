  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Oh, did you think that you were just going to watch your monsters fight
    for you? Nope! SMOL is a ghost after all. And what do ghosts usually do? They
    possess stuff! \r\n\r\nYou can move SMOL with the WASD keys towards a monster
    you previously place in your dungeon. When he is next to a monster or certain
    traps, press the SPACE BAR to possess the entity that is the closest to SMOL.
    \r\n\r\nBut careful! You cannot possess the heroes! They still have souls after
    all, and two souls cannot fit in a single body! \r\n\r\nWhen in possession mode,
    you can press the WASD keys to move monsters or, in certain cases, rotate traps.
    You can also press the left click to activate the main action of the entity being
    possessed, like the attack of a slime or to fire a crossbow.  \r\n\r\nWhen the
    monster SMOL possesses is killed, he turns back into a ghost. You can also stop
    the possession whenever you want by pressing the SPACE BAR again to turn back
    into a ghost without damaging the entity. "
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: d64da69360c2c66489c9deeb5f1c79c7, type: 2}
  m_sharedMaterial: {fileID: -6602767322224921027, guid: d64da69360c2c66489c9deeb5f1c79c7, type: 2}
