  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Ok, done with the dungeon! But\u2026 well\u2026 it's kind of empty, don\u2019t
    you think? I mean, look at this, humans just have to walk through the whole thing
    in a straight line and easily steal the treasure! We need more defences! \r\n\r\nBut
    don\u2019t worry, I have a solution; let's make some monsters and traps appear
    to slow down the heroes! After you finish setting up the dungeon, you can spend
    Evil Points      to place entities in the different rooms, so either monsters
    or traps."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 4e023ce55066c7649a636a490e6dc58d, type: 2}
  m_sharedMaterial: {fileID: -6204973913550994659, guid: 4e023ce55066c7649a636a490e6dc58d, type: 2}
