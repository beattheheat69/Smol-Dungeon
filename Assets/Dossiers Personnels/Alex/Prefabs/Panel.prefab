  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "To use the main boss action, press LEFT CLICK, just like how you control
    other monsters in the dungeon. \r\n\r\nTo use the two secondary actions of the
    bosses, press the Q and E keys. \r\n\r\nThe fight ends when one of two conditions
    is accomplished: either the heroes are defeated, and you can start the second
    day, or the boss is defeated, and it's game over! "
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: d64da69360c2c66489c9deeb5f1c79c7, type: 2}
  m_sharedMaterial: {fileID: -6602767322224921027, guid: d64da69360c2c66489c9deeb5f1c79c7, type: 2}
